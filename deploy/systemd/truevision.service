[Unit]
Description=TrueVision Pi Runtime
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/truevision
Environment=TRUEVISION_ENABLE_WINDOW=1
ExecStart=/opt/truevision/.venv/bin/python -m truevision_pi.main --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3
User=pi

[Install]
WantedBy=multi-user.target
